# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App (production: https://your-domain.com — no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Platform host for tenant subdomain resolution (default: host from NEXT_PUBLIC_APP_URL)
# JMS_PLATFORM_HOST="jms.nsd.id"

# Midtrans (APC payment — Sprint 13)
MIDTRANS_SERVER_KEY="Mid-server-..."
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="Mid-client-..."
MIDTRANS_IS_PRODUCTION="false"

# Duitku (optional alternate gateway)
DUITKU_MERCHANT_CODE=""
DUITKU_API_KEY=""
DUITKU_SANDBOX="true"

# Upstash Redis (rate-limit, tenant cache — Sprint 2+)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# OAI-PMH rate limit per host (requests/minute, default 30, range 5–300 — Sprint 26)
# OAI_RATE_LIMIT_PER_MIN="30"

# Custom domain (Sprint 4) — CNAME target clients point to
# JMS_CNAME_TARGET="cname.jms.nsd.id"

# Vercel Domains API (SSL auto-provision for custom domains)
# VERCEL_API_TOKEN=""
# VERCEL_PROJECT_ID=""
# VERCEL_TEAM_ID=""

# Cron auth for /api/cron/* (Vercel sends Authorization: Bearer)
# CRON_SECRET=""

# CrossRef DOI deposit (Sprint 12 — test environment by default)
# CROSSREF_DEPOSITOR_EMAIL="depositor@example.com"
# CROSSREF_DEPOSITOR_PASSWORD="your-crossref-password"
# CROSSREF_DEPOSITOR_NAME="NSD Platform"
# CROSSREF_REGISTRANT="NSD Platform"
# CROSSREF_IS_PRODUCTION="false"

# Supabase Storage bucket for submission manuscripts (Sprint 5)
# JMS_STORAGE_BUCKET="submissions"

# Similarity check — Copyleaks API (Sprint 16; mock provider when unset)
# COPYLEAKS_EMAIL="your@email.address"
# COPYLEAKS_API_KEY="00000000-0000-0000-0000-000000000000"
# COPYLEAKS_IS_SANDBOX="true"

# Similarity check — iThenticate / Turnitin Core API (Sprint 19)
# Without credentials, platform falls back to mock — GET /api/health/operational reports productionReady: false in NODE_ENV=production.
# SIMILARITY_PROVIDER="ithenticate"  # mock | copyleaks | ithenticate — set mock ONLY for demo/staging (explicit override)
# ITHENTICATE_API_URL="https://crossref-1234.turnitin.com"
# ITHENTICATE_API_KEY="your-api-key"
# ITHENTICATE_INTEGRATION_NAME="JMS-NSD"
# ITHENTICATE_INTEGRATION_VERSION="1.0.0"

# AI reviewer matching — OpenAI embeddings (Sprint 17; mock provider when OPENAI_API_KEY unset)
# Mock embedding in production also sets productionReady: false on /api/health/operational.
# OPENAI_API_KEY="sk-..."
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Sentry (optional in development)
SENTRY_DSN=""

# Resend (transactional email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="JMS <onboarding@resend.dev>"
