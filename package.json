    "db:seed:demo": "pnpm --filter @nsd/jms db:seed:demo",
    "db:provision:pilot": "pnpm --filter @nsd/jms db:provision:pilot"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
