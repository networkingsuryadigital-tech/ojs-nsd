{
  "name": "@nsd/jms",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "oai:load-test": "node --import tsx scripts/oai-load-test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed:demo": "vitest run scripts/seed-demo.harness.test.ts --config vitest.seed.config.ts",
    "db:seed:dummy": "vitest run scripts/seed-dummy.harness.test.ts --config vitest.seed.config.ts",
    "db:wipe:journals": "node --import tsx scripts/wipe-journals.ts",
    "db:provision:pilot": "node --import ./scripts/stub-server-only.ts --import tsx scripts/provision-pilot-journal.ts"
  },
  "dependencies": {
    "@nsd/auth": "workspace:*",
    "@nsd/email": "workspace:*",
    "@nsd/notifications": "workspace:*",
    "@nsd/observability": "workspace:*",
    "@nsd/payments": "workspace:*",
    "@nsd/storage": "workspace:*",
    "@nsd/ui": "workspace:*",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.95.3",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nsd/eslint-config": "workspace:*",
    "@nsd/tailwind-config": "workspace:*",
    "@nsd/tsconfig": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
